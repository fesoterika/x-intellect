<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Загруженные медиафайлы (/storage — симлинк на storage/app/public) отдаёт
# веб-сервер напрямую, минуя PHP: middleware SecurityHeaders до них не достаёт.
<IfModule mod_headers.c>
    # Ассеты Vite (/build/assets) несут хеш содержимого в имени файла —
    # при изменении меняется и имя, поэтому кешировать можно навсегда
    <FilesMatch "-[A-Za-z0-9_-]{8,}\.(css|js|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set X-Content-Type-Options "nosniff"
    </FilesMatch>

    # Медиа контента: имена архивных файлов содержательно-адресные (sha1),
    # загрузки из редактора получают новое случайное имя при перезаливке —
    # месяц кеша безопасен и снимает повторные скачивания со старых телефонов
    #
    # nosniff здесь, а не глобально: без него браузер угадывает тип по
    # содержимому и может исполнить загруженный файл как HTML — с домена
    # сайта. Ответы PHP тот же заголовок получают от middleware
    # SecurityHeaders, до статики он не достаёт — глобальная директива
    # дублировала бы его в каждом динамическом ответе
    <FilesMatch "\.(jpe?g|png|gif|webp|svg|ico|mp3|m4a|ogg|oga|wav|flac|pdf)$">
        Header set Cache-Control "public, max-age=2592000"
        Header set X-Content-Type-Options "nosniff"
    </FilesMatch>
</IfModule>

# Сжатие текстовых ответов (HTML страниц, CSS/JS, SVG): не полагаемся
# на настройки хостинга — на медленной мобильной сети это минус 70-80% веса
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml image/svg+xml
</IfModule>

# Аудио: явные типы, не полагаясь на mime.types хостинга. Из-за nosniff
# ошибочный Content-Type не «донюхивается» браузером, и плеер молча не играет
<IfModule mod_mime.c>
    AddType audio/mpeg .mp3
    AddType audio/mp4 .m4a
    AddType audio/wav .wav
    AddType audio/ogg .ogg .oga
    AddType audio/flac .flac
</IfModule>
