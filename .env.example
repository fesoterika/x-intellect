# ============================================================
# X-Intellect — пример конфигурации.
# Реальный .env НИКОГДА не коммитится (см. .gitignore) — заполняется
# на сервере один раз при первом деплое (Этап 8 плана).
# Значения ниже — БЕЗОПАСНЫЕ ДЛЯ ПРОДА: файл копируется на сервер как есть,
# поэтому APP_DEBUG=false и APP_ENV=production здесь по умолчанию (включённый
# отладчик показал бы посетителю трассировки со значениями .env).
# Локально после копирования: APP_ENV=local, APP_DEBUG=true, APP_URL=http://localhost.
# На проде (hosting.timeweb.ru): MySQL utf8mb4 (создать БД в панели Timeweb как UTF-8).
# ============================================================

APP_NAME="X-Intellect"
APP_ENV=production
# Свой на каждой установке: php artisan key:generate. Локальный ключ на прод НЕ переносить
APP_KEY=
APP_DEBUG=false
APP_URL=https://x-intellect.org

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Локальная разработка: sqlite. Прод: mysql + доступы из панели Timeweb.
# Основная БД — MySQL (utf8mb4, совместимость с 5.7). Для быстрого старта
# без MySQL можно раскомментировать sqlite-вариант ниже.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=x_intellect
DB_USERNAME=x_intellect
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Cookie сессии только по HTTPS. Локально (http://localhost) — false,
# иначе вход в админку не работает: браузер не вернёт cookie по http
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Database-очередь + cron (queue:work --stop-when-empty) — без
# постоянного воркер-процесса, под ограничения shared-хостинга
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@x-intellect.org"
MAIL_FROM_NAME="${APP_NAME}"

# Внешнее S3-совместимое хранилище — только если медиа не влезает
# в дисковый лимит тарифа (Этап 0/1 плана); код не меняется
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Первичный администратор для db:seed — сменить пароль после первого входа
SEED_ADMIN_EMAIL=admin@x-intellect.org
SEED_ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
